# ========================================
# GROVIX STUDIO - ENVIRONMENT CONFIGURATION
# ========================================
# IMPORTANT: Replace all placeholder values with your actual credentials
# See EMAIL_TWILIO_SETUP.md for detailed setup instructions

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# ========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ========================================
# 1. Enable 2FA: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password (remove spaces)

# Your Gmail account (used to SEND emails)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Your business email (where you RECEIVE inquiry notifications)
CLIENT_EMAIL=client-email@example.com

# ========================================
# TWILIO CONFIGURATION (WhatsApp)
# ========================================
# 1. Sign up: https://www.twilio.com/try-twilio
# 2. Get credentials: https://console.twilio.com/
# 3. Join WhatsApp sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=+14155238886

# ========================================
# DATABASE (Optional - defaults to SQLite)
# ========================================
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
